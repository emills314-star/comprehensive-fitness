{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schema/1.0.0/exercise_substitution_map.schema.json",
  "title": "exercise_substitution_map",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "exercise_substitution_map_id",
      "exercise_id",
      "substitute_exercise_id",
      "substitution_similarity",
      "reason",
      "confidence_rating"
    ],
    "properties": {
      "exercise_substitution_map_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "exercise_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "substitute_exercise_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "substitution_similarity": {
        "type": [
          "string",
          "null"
        ]
      },
      "reason": {
        "type": [
          "string",
          "null"
        ]
      },
      "confidence_rating": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "very_high",
          "high",
          "moderate",
          "low",
          "very_low",
          null
        ]
      }
    }
  }
}
