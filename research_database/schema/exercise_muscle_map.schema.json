{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schema/2.1.0/exercise_muscle_map.schema.json",
  "title": "exercise_muscle_map",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "exercise_muscle_map_id",
      "exercise_id",
      "muscle_group_id",
      "programming_family_id",
      "relationship_type",
      "loading_role",
      "range_of_motion_role",
      "fractional_set_credit",
      "local_fatigue_weight",
      "evidence_basis",
      "evidence_notes",
      "supporting_study_ids",
      "confidence_rating",
      "review_status",
      "taxonomy_version",
      "last_reviewed_date"
    ],
    "properties": {
      "exercise_muscle_map_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "exercise_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "muscle_group_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "programming_family_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "relationship_type": {
        "type": [
          "string",
          "null"
        ]
      },
      "loading_role": {
        "type": [
          "string",
          "null"
        ]
      },
      "range_of_motion_role": {
        "type": [
          "string",
          "null"
        ]
      },
      "fractional_set_credit": {
        "type": [
          "number",
          "null"
        ]
      },
      "local_fatigue_weight": {
        "type": [
          "number",
          "null"
        ]
      },
      "evidence_basis": {
        "type": [
          "string",
          "null"
        ]
      },
      "evidence_notes": {
        "type": [
          "string",
          "null"
        ]
      },
      "supporting_study_ids": {
        "type": [
          "string",
          "null"
        ]
      },
      "confidence_rating": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "very_high",
          "high",
          "moderate",
          "low",
          "very_low",
          null
        ]
      },
      "review_status": {
        "type": [
          "string",
          "null"
        ]
      },
      "taxonomy_version": {
        "type": [
          "string",
          "null"
        ]
      },
      "last_reviewed_date": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
