      "rule_id",
      "exercise_id"
    ],
    "properties": {
      "rule_exercise_map_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "rule_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "exercise_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  }
}
