{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schema/2.0.0/executive_summary.schema.json",
  "title": "executive_summary",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "summary_id",
      "topic",
      "applicable_male_population",
      "practical_recommendation",
      "evidence_strength",
      "confidence_rating",
      "important_exception_or_limitation",
      "supporting_study_ids",
      "last_reviewed_date"
    ],
    "properties": {
      "summary_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "topic": {
        "type": [
          "string",
          "null"
        ]
      },
      "applicable_male_population": {
        "type": [
          "string",
          "null"
        ]
      },
      "practical_recommendation": {
        "type": [
          "string",
          "null"
        ]
      },
      "evidence_strength": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "very_high",
          "high",
          "moderate",
          "low",
          "very_low",
          null
        ]
      },
      "confidence_rating": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "very_high",
          "high",
          "moderate",
          "low",
          "very_low",
          null
        ]
      },
      "important_exception_or_limitation": {
        "type": [
          "string",
          "null"
        ]
      },
      "supporting_study_ids": {
        "type": [
          "string",
          "null"
        ]
      },
      "last_reviewed_date": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
