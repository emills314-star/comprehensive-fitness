{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schema/3.0.0/exercise_taxonomy_review_queue.schema.json",
  "title": "exercise_taxonomy_review_queue",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "taxonomy_review_id",
      "exercise_id",
      "review_reason",
      "priority",
      "status",
      "taxonomy_version",
      "last_reviewed_date"
    ],
    "properties": {
      "taxonomy_review_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "exercise_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "review_reason": {
        "type": [
          "string",
          "null"
        ]
      },
      "priority": {
        "type": [
          "string",
          "null"
        ]
      },
      "status": {
        "type": [
          "string",
          "null"
        ]
      },
      "taxonomy_version": {
        "type": [
          "string",
          "null"
        ]
      },
      "last_reviewed_date": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
