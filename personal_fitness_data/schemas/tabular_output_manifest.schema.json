{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schemas/personal-fitness/v1/tabular_output_manifest.schema.json",
  "title": "Personal fitness tabular output manifest",
  "description": "Inventory and provenance contract for normalized and derived CSV, Parquet, and JSON tables produced by one analysis run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "analysis_id",
    "source_date_range",
    "analysis_date",
    "methodology_version",
    "sample_size",
    "confidence_level",
    "missing_data_flags",
    "source_references",
    "notes",
    "outputs"
  ],
  "properties": {
    "manifest_id": { "$ref": "#/$defs/stableId" },
    "analysis_id": { "$ref": "#/$defs/stableId" },
    "source_date_range": { "$ref": "#/$defs/dateRange" },
    "analysis_date": { "$ref": "#/$defs/isoDate" },
    "methodology_version": { "$ref": "#/$defs/version" },
    "sample_size": {
      "description": "Total rows across the listed tabular outputs. Individual analytical sample sizes remain in each output record.",
      "type": "integer",
      "minimum": 0
    },
    "confidence_level": { "$ref": "#/$defs/confidenceLevel" },
    "missing_data_flags": { "$ref": "#/$defs/missingDataFlags" },
    "source_references": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceReference" },
      "uniqueItems": true
    },
    "notes": { "$ref": "#/$defs/notes" },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/outputEntry" }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "isoDate": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "dateRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": {
          "type": ["string", "null"],
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end_date": {
          "type": ["string", "null"],
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "confidenceLevel": {
      "type": "string",
      "enum": ["high", "moderate", "low", "insufficient_personal_evidence"]
    },
    "missingDataFlags": {
      "type": "array",
      "items": { "$ref": "#/$defs/stableId" },
      "uniqueItems": true
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_path"],
      "properties": {
        "source_id": { "$ref": "#/$defs/stableId" },
        "source_path": { "type": "string", "minLength": 1 },
        "worksheet": { "type": ["string", "null"] },
        "source_record_id": { "type": ["string", "null"] },
        "source_row": { "type": ["integer", "null"], "minimum": 1 },
        "source_date": {
          "type": ["string", "null"],
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outputEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_id",
        "table_name",
        "relative_path",
        "format",
        "row_count",
        "sample_size",
        "stable_identifier_columns",
        "source_date_range",
        "analysis_date",
        "methodology_version",
        "confidence_level",
        "missing_data_flags",
        "source_references",
        "notes"
      ],
      "properties": {
        "output_id": { "$ref": "#/$defs/stableId" },
        "table_name": { "$ref": "#/$defs/stableId" },
        "relative_path": { "type": "string", "minLength": 1 },
        "format": {
          "type": "string",
          "enum": ["csv", "parquet", "json"]
        },
        "schema_path": { "type": ["string", "null"] },
        "row_count": { "type": "integer", "minimum": 0 },
        "sample_size": {
          "description": "Number of observations supporting the table or its aggregate results; this may differ from row_count.",
          "type": "integer",
          "minimum": 0
        },
        "stable_identifier_columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stableId" },
          "uniqueItems": true
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/stableId" },
          "uniqueItems": true
        },
        "checksum_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_date_range": { "$ref": "#/$defs/dateRange" },
        "analysis_date": { "$ref": "#/$defs/isoDate" },
        "methodology_version": { "$ref": "#/$defs/version" },
        "confidence_level": { "$ref": "#/$defs/confidenceLevel" },
        "missing_data_flags": { "$ref": "#/$defs/missingDataFlags" },
        "source_references": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceReference" },
          "uniqueItems": true
        },
        "notes": { "$ref": "#/$defs/notes" }
      }
    }
  }
}
