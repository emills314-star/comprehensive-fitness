{
  "name": "comprehensive-fitness",
  "version": "1.0.0",
  "private": true,
  "description": "A local-first workout tracker with transparent strength progression guidance.",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "22.23.x",
    "npm": "10.9.x"
  },
  "scripts": {
    "dev": "node scripts/serve-local.js",
    "sync:web": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-web.ps1",
    "verify:pwa": "node scripts/run-pwa-verification.js",
    "test:hypertrophy": "node scripts/test-hypertrophy-score.js",
    "test:resistance": "node scripts/test-resistance-model.js",
    "test:workout-safety": "node scripts/test-workout-safety.js",
    "test:workout-grade": "node scripts/test-workout-grade.js",
    "test:exercise-expectations": "node scripts/test-exercise-expectations.js",
    "test:domain-integrity": "node scripts/test-domain-integrity.js",
    "test:backup-contract": "node scripts/test-backup-contract.js",
    "test:sync-consent": "node scripts/test-sync-consent.js",
    "test:native-privacy": "node scripts/test-native-packaging-privacy.js",
    "test:service-worker-cache": "node scripts/test-service-worker-cache.js",
    "test:rest-warmup-targets": "node scripts/test-rest-warmup-targets.js",
    "test:rest-completion": "node scripts/test-rest-completion-controller.js",
    "test:rep-alert-cancel": "node scripts/test-rep-alert-cancel.js",
    "test:prescription-engine": "node scripts/test-prescription-engine.js",
    "test:prescription-schemas": "node scripts/test-prescription-schema-contracts.js",
    "test:prescription-integration": "node scripts/test-prescription-app-integration.js",
    "test:performance": "node scripts/test-performance.js",
    "test:set-prescriptions": "node scripts/test-set-prescriptions.js",
    "audit:ui": "playwright test",
    "audit:ui:update": "playwright test --update-snapshots",
    "audit:ui:report": "node scripts/generate-ui-audit-report.js",
    "preview:strong-migration": "node scripts/preview-strong-migration.js",
    "research:build": "node scripts/build-research-database.js",
    "research:validate": "node scripts/validate-research-database.js",
    "personal:build": "node scripts/build-personal-fitness-data.js",
    "personal:validate": "node scripts/validate-personal-fitness-data.js",
    "test:personal-data": "node scripts/test-personal-fitness-data.js",
    "build:app-evidence": "node scripts/build-app-personal-evidence.js",
    "lint": "node scripts/lint-static.js",
    "check:workflows": "node scripts/validate-workflows.js",
    "check:privacy": "node scripts/check-public-privacy.js",
    "check:clean-source": "node scripts/check-clean-source.js",
    "audit:dependencies:full": "node scripts/audit-dependencies.js full",
    "audit:dependencies:production": "node scripts/audit-dependencies.js production",
    "test:release-automation": "node scripts/test-release-automation.js",
    "test": "node scripts/run-public-tests.js",
    "test:public": "node scripts/run-public-tests.js",
    "test:private": "node scripts/run-private-tests.js",
    "test:all-local": "node scripts/run-check-suite.js all-local",
    "check:public": "node scripts/run-check-suite.js public",
    "release:verify": "node scripts/run-check-suite.js release",
    "cap:init": "npx cap init \"Comprehensive Fitness\" \"com.emills.comprehensivefitness\" --web-dir www",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.3",
    "@upstash/qstash": "^2.11.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@playwright/test": "^1.61.1",
    "axe-core": "^4.12.1",
    "exceljs": "^4.4.0",
    "jszip": "3.10.1",
    "yaml": "2.9.0"
  }
}
