{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schemas/mesocycle-plan.v1.schema.json",
  "title": "MesocyclePlan and diversified exercise candidate pools v1",
  "description": "A versioned full-program mesocycle plan. Program slots select a portfolio before the portfolio is distributed across sessions and validated for volume, fatigue, spinal load, grip, overlap, recovery, and duration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "type",
    "name",
    "status",
    "createdAt",
    "durationWeeks",
    "durationBasis",
    "specializationMuscleGroups",
    "trainingDays",
    "split",
    "availableEquipment",
    "constraints",
    "planningStep",
    "pools",
    "programSlots",
    "selectedPortfolio",
    "activeExercises",
    "sessions",
    "programReview",
    "preservedProductiveExerciseIds",
    "versions",
    "lifecycle"
  ],
  "properties": {
    "id": {
      "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
    },
    "schemaVersion": {
      "enum": ["mesocycle/1.0.0", "mesocycle/2.0.0", "mesocycle/2.1.0", "mesocycle/2.2.0", "mesocycle/2.3.0", "mesocycle/2.4.0"]
    },
    "type": {
      "$ref": "#/$defs/mesocycleType"
    },
    "name": {
      "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
    },
    "status": {
      "$ref": "#/$defs/mesocycleStatus"
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "durationWeeks": {
      "type": "integer",
      "minimum": 2,
      "maximum": 12
    },
    "durationBasis": {
      "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
    },
    "specializationMuscleGroups": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
      }
    },
    "trainingDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 14
    },
    "split": {
      "anyOf": [
        {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        {
          "type": "null"
        }
      ]
    },
    "availableEquipment": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
      }
    },
    "constraints": { "type": "object", "additionalProperties": true },
    "planningStep": { "type": "integer", "minimum": 1, "maximum": 10 },
    "availableMuscleGroupIds": { "$ref": "#/$defs/idList" },
    "includedMuscleGroupIds": { "$ref": "#/$defs/idList" },
    "equipmentUnavailableMuscleGroupIds": { "$ref": "#/$defs/idList" },
    "omittedMuscleGroups": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["muscleGroupId", "importance", "explanation"], "properties": { "muscleGroupId": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }, "importance": { "enum": ["major", "smaller"] }, "reasonCode": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }, "explanation": { "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString" } } } },
    "scopeConfirmed": { "type": "boolean" },
    "currentProgramExerciseIds": { "$ref": "#/$defs/idList" },
    "recentExerciseWindowDays": { "type": "integer", "minimum": 1 },
    "pools": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/candidatePool"
      }
    },
    "activeExercises": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activeExercise"
      }
    },
    "selectedPortfolio": {
      "type": "array",
      "items": { "$ref": "#/$defs/activeExercise" }
    },
    "programSlots": {
      "type": "array",
      "items": { "$ref": "#/$defs/programSlot" }
    },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/programSession" }
    },
    "programReview": { "$ref": "#/$defs/programReview" },
    "preservedProductiveExerciseIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
      }
    },
    "versions": {
      "$ref": "#/$defs/evidenceVersions"
    },
    "lifecycle": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lifecycleEvent"
      }
    },
    "startedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "completedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "outcome": {
      "$ref": "#/$defs/mesocycleOutcome"
    },
    "reviewedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "review": {
      "$ref": "#/$defs/mesocycleReview"
    }
  },
  "$defs": {
    "dateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "mesocycleType": {
      "type": "string",
      "enum": [
        "primary_progression",
        "alternative_exercise",
        "lower_fatigue_resensitization",
        "specialization"
      ]
    },
    "mesocycleStatus": {
      "type": "string",
      "enum": [
        "preview",
        "loaded",
        "draft",
        "planned",
        "active",
        "completed",
        "reviewed",
        "abandoned",
        "archived"
      ]
    },
    "candidatePool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "muscleGroupId",
        "mesocycleType",
        "generatedAt",
        "candidateCount",
        "availableViableExerciseCount",
        "candidates",
        "diversificationApplied",
        "explanation"
      ],
      "properties": {
        "muscleGroupId": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
        },
        "mesocycleType": {
          "$ref": "#/$defs/mesocycleType"
        },
        "generatedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "candidateCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "availableViableExerciseCount": {
          "type": "integer",
          "minimum": 0
        },
        "candidates": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/candidate"
          }
        },
        "diversificationApplied": {
          "type": "boolean"
        },
        "explanation": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "excludedCandidates": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "sourceMuscleGroupIds": { "$ref": "#/$defs/idList" }
      }
    },
    "candidateCore": {
      "type": "object",
      "required": [
        "rank",
        "rawScoreRank",
        "exerciseId",
        "researchExerciseId",
        "exerciseName",
        "intendedRole",
        "primaryMuscles",
        "secondaryMuscles",
        "equipmentRequirements",
        "jointActions",
        "recommendedSetStructure",
        "setStructureReason",
        "recommendedSetRange",
        "recommendedRepRange",
        "recommendedRpe",
        "recommendedRir",
        "recommendedFrequency",
        "progressionMethod",
        "progressionInstruction",
        "deloadTrigger",
        "rotationTrigger",
        "preferredReplacementExerciseId",
        "reasonForMesocycle",
        "personalDataConfidence",
        "researchDataConfidence",
        "scores",
        "diversitySignature"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "rawScoreRank": {
          "type": "integer",
          "minimum": 1
        },
        "exerciseId": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
        },
        "researchExerciseId": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nullableId"
        },
        "exerciseName": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "intendedRole": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/role"
        },
        "primaryMuscles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
          }
        },
        "secondaryMuscles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
          }
        },
        "equipmentRequirements": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }
          }
        },
        "jointActions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }
        },
        "recommendedSetStructure": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/setStructure"
        },
        "setStructureReason": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "recommendedSetRange": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/setRange"
        },
        "recommendedRepRange": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/repRange"
        },
        "recommendedRpe": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/rpeRange"
        },
        "recommendedRir": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/rirRange"
        },
        "recommendedFrequency": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/frequencyRange"
        },
        "progressionMethod": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/progressionMethod"
        },
        "progressionInstruction": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "deloadTrigger": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "rotationTrigger": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "preferredReplacementExerciseId": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nullableId"
        },
        "reasonForMesocycle": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "personalDataConfidence": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/confidence"
        },
        "researchDataConfidence": {
          "type": "string",
          "enum": [
            "high",
            "moderate",
            "low",
            "very_low"
          ]
        },
        "scores": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/exerciseScoreBreakdown"
        },
        "diversitySignature": {
          "$ref": "#/$defs/diversitySignature"
        },
        "sourceTrace": { "type": "object", "additionalProperties": true },
        "scoreExplanation": { "type": "object", "additionalProperties": true }
      }
    },
    "candidate": {
      "allOf": [
        {
          "$ref": "#/$defs/candidateCore"
        }
      ],
      "unevaluatedProperties": false
    },
    "diversitySignature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "movement",
        "equipment",
        "equipmentRequirements",
        "jointActions",
        "region",
        "stability",
        "loading"
      ],
      "properties": {
        "movement": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "equipment": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "equipmentRequirements": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }
          }
        },
        "jointActions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" }
        },
        "region": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "stability": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "loading": {
          "type": "string",
          "enum": [
            "high_load",
            "moderate_load",
            "moderate_light_load"
          ]
        }
      }
    },
    "activeExercise": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/candidateCore"
        }
      ],
      "required": [
        "muscleGroupId",
        "targetMuscleGroupIds",
        "selectionReason"
      ],
      "properties": {
        "muscleGroupId": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
        },
        "targetMuscleGroupIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
          }
        },
        "selectionReason": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        },
        "programSlotIds": { "$ref": "#/$defs/idList" },
        "targetMuscleEffectiveness": { "$ref": "exercise-prescription.v2.schema.json#/$defs/score" },
        "fullProgramFit": { "$ref": "exercise-prescription.v2.schema.json#/$defs/score" },
        "predictedProgramEffectiveness": { "$ref": "exercise-prescription.v2.schema.json#/$defs/score" },
        "positiveFactors": { "type": "array", "items": { "type": "string" } },
        "limitingFactors": { "type": "array", "items": { "type": "string" } }
        ,"plannedSets": { "type": "integer", "minimum": 0 },
        "weeklySets": { "type": "integer", "minimum": 0 },
        "exposureIndex": { "type": "integer", "minimum": 1 }
      },
      "unevaluatedProperties": false
    },
    "programSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "muscleGroupId", "trainingPurpose", "role", "selectionRequired", "selectedExerciseIds", "candidateExerciseIds", "weeklySetsTarget", "weeklyExposuresTarget", "plannedSessionIds", "rationale"],
      "properties": {
        "id": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" },
        "muscleGroupId": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" },
        "trainingPurpose": { "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString" },
        "role": { "$ref": "exercise-prescription.v2.schema.json#/$defs/role" },
        "selectionRequired": { "type": "integer", "minimum": 1, "maximum": 3 },
        "selectedExerciseIds": { "$ref": "#/$defs/idList" },
        "candidateExerciseIds": { "$ref": "#/$defs/idList" },
        "weeklySetsTarget": { "type": "number", "minimum": 0 },
        "weeklySetsRange": { "type": "object", "additionalProperties": false, "required": ["min", "target", "max"], "properties": { "min": { "type": "number", "minimum": 0 }, "target": { "type": "number", "minimum": 0 }, "max": { "type": "number", "minimum": 0 } } },
        "weeklyExposuresTarget": { "type": "number", "minimum": 0 },
        "plannedSessionIds": { "$ref": "#/$defs/idList" },
        "rationale": { "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString" }
      }
    },
    "programSession": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "dayIndex", "name", "baseSessionIntent", "exercises", "estimatedDurationMinutes", "systemicFatigue", "spinalLoad", "gripDemand", "jointStress"],
      "properties": {
        "id": { "$ref": "exercise-prescription.v2.schema.json#/$defs/id" },
        "dayIndex": { "type": "integer", "minimum": 0 },
        "name": { "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString" },
        "baseSessionIntent": { "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString" },
        "exercises": { "type": "array", "items": { "$ref": "#/$defs/activeExercise" } },
        "estimatedDurationMinutes": { "type": "number", "minimum": 0 },
        "systemicFatigue": { "type": "number", "minimum": 0 },
        "spinalLoad": { "type": "number", "minimum": 0 },
        "gripDemand": { "type": "number", "minimum": 0 },
        "jointStress": { "type": "number", "minimum": 0 }
      }
    },
    "programReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warnings", "seriousWarningCount", "musclePlans", "explanation"],
      "properties": {
        "warnings": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "seriousWarningCount": { "type": "integer", "minimum": 0 },
        "blockingIssueCount": { "type": "integer", "minimum": 0 },
        "musclePlans": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "explanation": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidenceVersions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "personal",
        "research"
      ],
      "properties": {
        "engine": {
          "$ref": "#/$defs/semanticVersion"
        },
        "personal": {
          "$ref": "#/$defs/versionIdentifier"
        },
        "research": {
          "$ref": "#/$defs/versionIdentifier"
        }
      }
    },
    "semanticVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "versionIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "lifecycleEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "at"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/mesocycleStatus"
        },
        "at": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "mesocycleOutcome": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "completedWeeks": {
          "type": "number",
          "minimum": 0
        },
        "completedWorkouts": {
          "type": "integer",
          "minimum": 0
        },
        "adherencePercent": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/percentage"
        },
        "progressingExerciseIds": {
          "$ref": "#/$defs/idList"
        },
        "stalledExerciseIds": {
          "$ref": "#/$defs/idList"
        },
        "rotatedExerciseIds": {
          "$ref": "#/$defs/idList"
        },
        "summary": {
          "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "idList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "exercise-prescription.v2.schema.json#/$defs/id"
      }
    },
    "mesocycleReview": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "keepExerciseIds": {
          "$ref": "#/$defs/idList"
        },
        "rotationCandidateIds": {
          "$ref": "#/$defs/idList"
        },
        "nextMesocycleType": {
          "$ref": "#/$defs/mesocycleType"
        },
        "evidenceSummary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "exercise-prescription.v2.schema.json#/$defs/nonEmptyString"
          }
        }
      }
    }
  }
}
