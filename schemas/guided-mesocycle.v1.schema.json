{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comprehensive-fitness.local/schemas/guided-mesocycle.v1.schema.json",
  "title": "Guided Mesocycle Draft v1",
  "type": "object",
  "required": ["id", "schemaVersion", "builderMode", "rulesVersion", "name", "type", "status", "durationWeeks", "trainingDays", "planningProgress", "guidedDays", "acceptedExceptions", "revision", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "schemaVersion": { "enum": ["guided-mesocycle/1.0.0", "guided-mesocycle/1.1.0"] },
    "builderMode": { "const": "guided" },
    "rulesVersion": { "enum": ["planning-rules/1.0.0", "planning-rules/1.1.0"] },
    "name": { "type": "string", "minLength": 1 },
    "type": { "enum": ["primary_progression", "alternative_exercise", "lower_fatigue_resensitization", "specialization"] },
    "status": { "enum": ["draft", "planned", "active", "completed", "abandoned", "archived"] },
    "durationWeeks": { "type": "integer", "minimum": 2, "maximum": 12 },
    "trainingDays": { "type": "integer", "minimum": 1, "maximum": 7 },
    "availableEquipment": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "includedMuscleGroupIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "musclePriorities": { "type": "object", "additionalProperties": { "enum": ["maintenance", "normal", "priority", "specialization"] } },
    "planningProgress": {
      "type": "object",
      "required": ["highestUnlockedStep", "completedSteps", "setupRevision", "buildRevision"],
      "properties": {
        "highestUnlockedStep": { "enum": ["guide", "setup", "build", "check", "create"] },
        "completedSteps": { "type": "array", "items": { "enum": ["guide", "setup", "build", "check", "create"] }, "uniqueItems": true },
        "setupRevision": { "type": "integer", "minimum": 0 },
        "buildRevision": { "type": "integer", "minimum": 0 },
        "viabilityRevision": { "type": ["integer", "null"], "minimum": 0 },
        "createReadyRevision": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "guidedDays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "ordinal", "name", "assignments"],
        "properties": {
          "id": { "type": "string" }, "ordinal": { "type": "integer", "minimum": 1 }, "name": { "type": "string", "minLength": 1 },
          "assignments": { "type": "array", "items": { "type": "object", "required": ["id", "exerciseId", "name", "workingSets", "repRange", "setStructure"], "properties": { "id": { "type": "string" }, "exerciseId": { "type": "string" }, "canonicalExerciseId": { "type": "string" }, "name": { "type": "string" }, "workingSets": { "type": "integer", "minimum": 1 }, "targetMuscleEffectiveness": { "type": "number", "minimum": 0, "maximum": 100 }, "confidence": { "type": "string" }, "repRange": { "type": "object" }, "setStructure": { "type": "string" } }, "additionalProperties": true } }
        },
        "additionalProperties": true
      }
    },
    "acceptedExceptions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "viabilityResult": { "type": ["object", "null"] },
    "viabilityStale": { "type": "boolean" },
    "linkedTemplateIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "creationResult": { "type": "object", "required": ["operationId", "completedAt", "createdCount", "updatedCount", "templateCount", "templateIds"], "properties": { "operationId": { "type": "string" }, "completedAt": { "type": "string", "format": "date-time" }, "createdCount": { "type": "integer", "minimum": 0 }, "updatedCount": { "type": "integer", "minimum": 0 }, "templateCount": { "type": "integer", "minimum": 0 }, "templateIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }, "acceptedWarningIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true } }, "additionalProperties": false },
    "revision": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
